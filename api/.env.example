# kin API server — local dashboard service.
#
# SECURITY: By default this service should be bound to 127.0.0.1 only.
# Exposing it on a routable network interface without setting KIN_API_KEY
# is a privacy risk — any peer that can reach the port can read email data.
#
# Set KIN_API_KEY to require an X-API-Key header on every request when you
# need to accept connections beyond loopback.

KIN_USER=jerome
# KIN_DEMO_USER=   # optional: maps session users to this kin user_id
# KIN_DB_PATH=     # optional: override DB path (default: data/kin.sqlite)
#                  # must point to a .sqlite or .db file
# KIN_API_KEY=     # optional: shared-secret for X-API-Key header auth
#                  # required if the service is not bound to 127.0.0.1
