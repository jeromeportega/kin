# NextAuth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth credentials — create at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# kin API base URL (the FastAPI server)
KIN_API_BASE_URL=http://127.0.0.1:8000

# Optional: map authenticated users to this kin user_id (demo / single-user mode)
KIN_DEMO_USER=
