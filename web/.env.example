# kin web (Next.js) — copy to .env.local and fill in. Never commit real values.
# Only AUTH_* + Google are required to run locally; everything else is optional
# or feature-gated (the app degrades gracefully when a section is unset).

# ── Auth (required) ───────────────────────────────────────────────────────────
# NextAuth/Auth.js session secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth credentials — create at https://console.cloud.google.com/
# auth.ts accepts either the GOOGLE_* names or Auth.js's AUTH_GOOGLE_* aliases.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# Optional: canonical URL for local dev. In deploys `trustHost: true` derives the
# URL + OAuth callback from the request, so this is not needed in production.
# AUTH_URL=http://localhost:3000

# ── Database (Turso / libSQL) ─────────────────────────────────────────────────
# Production points at Turso; set both in Vercel. When unset, the app falls back
# to a local SQLite file (KIN_DB_PATH, default ../data/kin.sqlite), which is what
# dev + tests use — so you can leave these blank locally.
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=
# KIN_DB_PATH=./data/kin.sqlite

# ── Cron (Vercel) ─────────────────────────────────────────────────────────────
# /api/cron requires `Authorization: Bearer $CRON_SECRET`. Set in Vercel; only
# needed if you exercise the scheduled sync locally.
# CRON_SECRET=

# ── Plaid (finance bank connectivity) ─────────────────────────────────────────
# The /finance "Connect a bank" UI appears only when PLAID_CLIENT_ID + PLAID_SECRET
# are set. From the Plaid dashboard → Keys:
#   Client ID        → PLAID_CLIENT_ID
#   Sandbox Secret   → PLAID_SECRET   (while PLAID_ENV=sandbox)
#   Production Secret→ PLAID_SECRET   (only when you flip PLAID_ENV=production)
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox
# Only needed for OAuth banks (Chase, etc.). Must be added verbatim to the Plaid
# dashboard's "Allowed redirect URIs". Omit for sandbox test institutions.
# PLAID_REDIRECT_URI=https://kin-one-alpha.vercel.app/finance

# ── Misc ──────────────────────────────────────────────────────────────────────
# Optional: pin authenticated users to a single kin user_id (demo / single-user).
# KIN_DEMO_USER=
