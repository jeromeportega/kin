# kin — local-first AI for personal/family workflows
# Copy to .env and fill in. After copying: chmod 600 .env

# Phase 2 — Gmail / IMAP
# (App password requires 2FA on the Gmail account; generate one at
# https://myaccount.google.com/apppasswords)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# Logging verbosity for kin (DEBUG / INFO / WARNING / ERROR). Defaults to INFO.
# KIN_LOG_LEVEL=INFO

# Phase 3 — Persistence
# Default DB path is data/kin.sqlite; uncomment to override.
# KIN_DB_PATH=./data/kin.sqlite

# User scope for forward-compat multi-user support. Defaults to 'jerome'.
# KIN_USER=jerome
